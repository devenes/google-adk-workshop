# Copy to `.env` in this directory (or set in your shell). Never commit `.env`.
# ADK Web may load `.env` next to an agent folder depending on your setup.

# Gemini API (Google AI Studio) — used by workshop demos by default
GOOGLE_API_KEY=

# Vertex AI (optional — use instead of Gemini API key when required)
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
